# syntax=docker/dockerfile:1.6
# ============================================================================
# ARCHITECTURE : CLOUD-NATIVE DEPLOYMENT COMPILATION MATRIX (50+ YRS EXP SPEC)
# APPLICATION  : SHAKIB MIA ULTRAGOD PORTFOLIO RUNTIME ENVIRONMENT
# PARADIGM     : HIGH-SCALE, HERMETICALLY SEALED MULTI-STAGE EDGE ARCHITECTURE
# ============================================================================

# --- GLOBAL SYSTEM CONFIGURATION & ARGUMENT MATRIX ---
ARG RUNTIME_NODE_IMAGE=node:22-alpine
ARG APP_SANDBOX_DIR=/enterprise/infrastructure/runtime

# ============================================================================
# PASS 1: DETERMINISTIC DEPENDENCY COMPILER & CACHE GATEKEEPER
# ============================================================================
FROM ${RUNTIME_NODE_IMAGE} AS dependency_compiler
ARG APP_SANDBOX_DIR
WORKDIR ${APP_SANDBOX_DIR}

# Install essential system-level build primitives inside the secure compiler context
RUN apk add --no-cache libc6-compat python3 make g++

# Layer Cache Optimization: Bind mounts prevent raw package pollution on target layers
COPY package.json package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci --prefer-offline --no-audit --progress=false

# ============================================================================
# PASS 2: PRODUCTION BUILD ENGINE & STATIC HYDRATION LAYER
# ============================================================================
FROM ${RUNTIME_NODE_IMAGE} AS asset_hydrator
ARG APP_SANDBOX_DIR
WORKDIR ${APP_SANDBOX_DIR}

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Pull cached build nodes directly from the dependency compiler stage
COPY --from=dependency_compiler ${APP_SANDBOX_DIR}/node_modules ./node_modules
COPY . .

# Compile and optimize the framework output target (Next.js Standalone Mode)
RUN npm run build

# Clean deep-level dev dependencies that managed to slip into the workspace
RUN rm -rf node_modules && \
    --mount=type=cache,target=/root/.npm \
    npm prunes --production

# ============================================================================
# PASS 3: HIGH-SECURITY DISTROLESS-INSPIRED PRODUCTION EDGE ENGINE
# ============================================================================
FROM ${RUNTIME_NODE_IMAGE} AS production_edge_gateway
ARG APP_SANDBOX_DIR
WORKDIR ${APP_SANDBOX_DIR}

# Global Runtime Environment Variables
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Enforce Non-Root Execution Privilege Level (Zero-Trust Security Vector)
RUN addgroup --system --gid 1001 ultrafaang_cloud_group && \
    adduser --system --uid 1001 ultrafaang_cloud_architect

# Pull exclusively isolated Next.js runtime build artifacts from Stage 2
COPY --from=asset_hydrator --chown=ultrafaang_cloud_architect:ultrafaang_cloud_group ${APP_SANDBOX_DIR}/public ./public
COPY --from=asset_hydrator --chown=ultrafaang_cloud_architect:ultrafaang_cloud_group ${APP_SANDBOX_DIR}/.next/standalone ./
COPY --from=asset_hydrator --chown=ultrafaang_cloud_architect:ultrafaang_cloud_group ${APP_SANDBOX_DIR}/.next/static ./.next/static

# System Entry Permissions Configuration
USER ultrafaang_cloud_architect
EXPOSE 3000

# Edge Level Health Diagnostics Interceptor Loop
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"

# Bootstrap Next.js microserver standalone entry node
CMD ["node", "server.js"]